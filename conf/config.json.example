{
    "generator": {
        "deepseek": {
            "api_key": "<DEEPSEEK API KEY>",
            "base_url": "https://api.deepseek.com",
            "model": "deepseek-v4-pro",
            "evaluator_model": "deepseek-v4-flash",
            "temperature": 0.9,
            "max_tokens": 500
        }
    },
    "irc": {
        "host": "irc.libera.chat",
        "port": 6697,
        "tls": true,
        "nick": "IsaacGPT",
        "username": "IsaacGPT",
        "realname": "Isaac the Robot",
        "password": "<NickServ password (optional, for SASL auth)>",
        "sasl": true,
        "channels": ["#amiantos"],
        "max_line_length": 340,
        "watchword": "Isaac",
        "pm_allowed_users": [],
        "typing_notifications": {
            "enabled": true,
            "refresh_seconds": 3
        }
    },
    "autonomous": {
        "enabled": true,
        "debounce_seconds": 3,
        "max_context_age_minutes": 30,
        "max_conversation_gap_minutes": 30
    },
    "vision": {
        "enabled": false,
        "supported_formats": ["png", "jpg", "jpeg", "gif", "webp"],
        "max_file_size_mb": 20
    },
    "openai": {
        "api_key": "<OPENAI API KEY>",
        "model": "gpt-4o",
        "max_tokens": 300
    },
    "web": {
        "enabled": true,
        "port": 3000,
        "auth": {
            "username": "admin",
            "password": "<DASHBOARD_PASSWORD>"
        }
    },
    "kagi": {
        "api_key": "<KAGI API KEY (optional, for web search and URL summarization)>"
    },
    "url_summarize": {
        "enabled": true,
        "summary_type": "takeaway",
        "max_urls_per_message": 3
    }
}
