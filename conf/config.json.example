{
    "generator": {
        "deepseek": {
            "api_key": "<DEEPSEEK API KEY>",
            "base_url": "https://api.deepseek.com",
            "model": "deepseek-chat",
            "temperature": 0.9,
            "max_tokens": 500
        }
    },
    "irc": {
        "host": "irc.libera.chat",
        "port": 6697,
        "tls": true,
        "nick": "IsaacGPT",
        "username": "IsaacGPT",
        "realname": "Isaac the Robot",
        "password": "<NickServ password (optional, for SASL auth)>",
        "sasl": true,
        "channels": ["#amiantos"],
        "max_line_length": 400,
        "watchword": "Isaac"
    },
    "autonomous": {
        "enabled": true,
        "debounce_seconds": 15,
        "max_context_age_minutes": 30,
        "max_conversation_gap_minutes": 30
    },
    "vision": {
        "enabled": false,
        "supported_formats": ["png", "jpg", "jpeg", "gif", "webp"],
        "max_file_size_mb": 20
    },
    "openai": {
        "api_key": "<OPENAI API KEY>",
        "model": "gpt-4o",
        "max_tokens": 300
    },
    "web": {
        "enabled": true,
        "port": 3000,
        "auth": {
            "username": "admin",
            "password": "<DASHBOARD_PASSWORD>"
        }
    },
    "kagi": {
        "api_key": "<KAGI API KEY (optional, for web search and URL summarization)>"
    },
    "github_webhook": {
        "enabled": true,
        "secret": "<GITHUB_WEBHOOK_SECRET>",
        "channel": "#amiantos"
    },
    "url_summarize": {
        "enabled": true,
        "summary_type": "takeaway",
        "max_urls_per_message": 3
    },
    "chat_log_upload": {
        "enabled": true,
        "interval_seconds": 60,
        "log_file": "/usr/src/app/irc-logs/#amiantos.log",
        "tail_lines": 40,
        "r2": {
            "endpoint": "<R2_ENDPOINT_URL>",
            "bucket": "bradroot",
            "access_key_id": "<R2_ACCESS_KEY_ID>",
            "secret_access_key": "<R2_SECRET_ACCESS_KEY>",
            "key": "chat-log.txt"
        }
    }
}
